generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum OtpPurpose {
  REGISTER
  EMAIL_CHANGE
}

model ShopClient {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  name            String    @db.VarChar(120)
  phone           String?   @db.VarChar(40)
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  orders        Order[]
  refreshTokens RefreshToken[]
  otps          EmailOtp[]

  @@map("clients")
}

model EmailOtp {
  id         String     @id @default(cuid())
  email      String     @db.VarChar(160)
  codeHash   String     @map("code_hash") @db.VarChar(128)
  purpose    OtpPurpose
  clientId   String?    @map("client_id")
  /// Pending value for EMAIL_CHANGE (new email)
  payload    String?    @db.VarChar(160)
  attempts   Int        @default(0)
  expiresAt  DateTime   @map("expires_at")
  consumedAt DateTime?  @map("consumed_at")
  createdAt  DateTime   @default(now()) @map("created_at")

  client ShopClient? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@index([clientId])
  @@index([expiresAt])
  @@map("email_otps")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash") @db.VarChar(128)
  clientId  String    @map("client_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  client ShopClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String   @db.VarChar(120)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens AdminRefreshToken[]

  @@map("admins")
}

model AdminRefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash") @db.VarChar(128)
  adminId   String    @map("admin_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@map("admin_refresh_tokens")
}

model Category {
  id            String   @id // e.g. coffee-beans
  slug          String   @unique
  name          String   @db.VarChar(80)
  nameAr        String?  @map("name_ar") @db.VarChar(80)
  description   String?  @db.Text
  descriptionAr String?  @map("description_ar") @db.Text
  imagePath     String   @default("/assets/category-coffee-beans.png") @map("image_path") @db.VarChar(512)
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([isActive, sortOrder])
  @@map("categories")
}

model Product {
  id            String        @id // stable business id / slug
  slug          String        @unique
  categoryId    String        @map("category_id")
  name          String        @db.VarChar(160)
  nameAr        String?       @map("name_ar") @db.VarChar(160)
  description   String        @db.Text
  descriptionAr String?       @map("description_ar") @db.Text
  /// Base price in major units (QAR), e.g. 69.00
  price         Decimal       @db.Decimal(10, 2)
  discountType DiscountType? @map("discount_type")
  /// FIXED = amount off price; PERCENTAGE = % off price (e.g. 20 = 20%)
  discount     Decimal?      @db.Decimal(10, 2)
  imagePath    String        @map("image_path") @db.VarChar(512)
  quantity     Int           @default(0)
  inStock      Boolean       @default(true) @map("in_stock")
  isFeatured   Boolean       @default(false) @map("is_featured")
  isActive     Boolean       @default(true) @map("is_active")
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@index([categoryId, isActive])
  @@index([isFeatured, isActive])
  @@index([inStock])
  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @map("order_number") @db.VarChar(32)
  clientId        String?     @map("client_id")
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @map("delivery_fee") @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  guestName       String      @map("guest_name") @db.VarChar(120)
  guestEmail      String      @map("guest_email") @db.VarChar(160)
  guestPhone      String      @map("guest_phone") @db.VarChar(40)
  deliveryCity    String      @map("delivery_city") @db.VarChar(80)
  deliveryAddress String      @map("delivery_address") @db.VarChar(255)
  notes           String?     @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  client ShopClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items  OrderItem[]

  @@index([clientId, createdAt])
  @@index([status, createdAt])
  @@index([guestEmail])
  @@map("orders")
}

model OrderItem {
  id           String        @id @default(cuid())
  orderId      String        @map("order_id")
  productId    String?       @map("product_id")
  /// Snapshot fields — keep history even if product price/discount changes
  productSlug  String        @map("product_slug") @db.VarChar(120)
  productName  String        @map("product_name") @db.VarChar(160)
  imagePath    String        @default("") @map("image_path") @db.VarChar(512)
  unitPrice    Decimal       @map("unit_price") @db.Decimal(10, 2)
  discountType DiscountType? @map("discount_type")
  discount     Decimal?      @db.Decimal(10, 2)
  quantity     Int
  total        Decimal       @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Subscriber {
  id             String    @id @default(cuid())
  email          String    @unique @db.VarChar(160)
  isActive       Boolean   @default(true) @map("is_active")
  subscribedAt   DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")

  @@map("subscribers")
}
