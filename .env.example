# Local (XAMPP / local MySQL) — use this on your PC
DATABASE_URL="mysql://root@127.0.0.1:3306/solv"

# Production (Easypanel) — use this only on the deployed server
# DATABASE_URL="mysql://USER:PASSWORD@amctag_db_solv:3306/db_solv"

JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS="30"

# Seeded admin account (change in production)
ADMIN_EMAIL="admin@solv.qa"
ADMIN_PASSWORD="Admin123!"
ADMIN_NAME="Solv Admin"

# Local app URL while developing
APP_URL="http://localhost:3000"
APP_NAME="Solv"
# Production:
# APP_URL="https://amctag-solv.38f0fz.easypanel.host"

# Remote image upload (ispot)
UPLOAD_API_URL="https://st79068.ispot.cc/solv/upload.php"
UPLOAD_API_TOKEN="YourSuperSecretToken2026!@#"
UPLOAD_PUBLIC_BASE_URL="https://st79068.ispot.cc/solv"

# SMTP (order emails) — AMC mail server
MAIL_HOST="mail.amcserver.com"
MAIL_PORT="587"
MAIL_ENCRYPTION="ssl"
MAIL_USERNAME="teamsdeveloper@amcserver.com"
MAIL_PASSWORD="your-smtp-password"
MAIL_FROM_ADDRESS="teamsdeveloper@amcserver.com"
MAIL_FROM_NAME="Taaruf"
# Inbox that receives new-order alerts (defaults to MAIL_USERNAME)
MAIL_ORDER_NOTIFY_TO="teamsdeveloper@amcserver.com"
# Contact form inbox (defaults to MAIL_ORDER_NOTIFY_TO / MAIL_FROM_ADDRESS)
MAIL_CONTACT_TO="teamsdeveloper@amcserver.com"
